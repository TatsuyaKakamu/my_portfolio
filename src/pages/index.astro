---
import {
  Activity,
  BadgeCheck,
  Camera,
  Clock,
  CodeXml,
  ExternalLink,
  Flame,
  Hourglass,
  House,
  Image as ImageIcon,
  Link as LinkIcon,
  ShieldCheck,
  UserRound
} from "@lucide/astro";
import {
  activityAreas,
  certification,
  externalLinks,
  photos,
  profile,
  projects,
  training
} from "../data/portfolio";
import MetricCard from "../components/MetricCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { asset } from "../lib/asset";
import "../styles/global.css";

const iconMap = {
  home: House,
  code: CodeXml,
  shield: ShieldCheck,
  camera: Camera,
  runner: Activity,
  user: UserRound,
  github: CodeXml,
  tuv: BadgeCheck,
  instagram: Camera,
  strava: Activity
};

const navItems = activityAreas.filter((item) => item.id !== "home");
const sectionIconMap = {
  apps: CodeXml,
  security: ShieldCheck,
  photography: Camera,
  training: Activity,
  about: UserRound
};
const instagramUrl = externalLinks.find((item) => item.icon === "instagram")?.url;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Tatsuya Kakamuのアプリ開発、産業用サイバーセキュリティ、写真、トレーニングをまとめたポートフォリオ。"
    />
    <title>{profile.name} | Portfolio</title>
  </head>
  <body>
    <div class="site-shell" id="home">
      <header class="topbar" aria-label="Primary navigation">
        <a class="brand" href="#home" aria-label={`${profile.name} home`}>
          <span class="brand-mark">{profile.initials}</span>
          <span>{profile.name}</span>
        </a>
        <nav class="nav-links" aria-label="Section navigation">
          <a class="nav-link is-active" href="#home">
            <House size={17} aria-hidden="true" />
            <span>Home</span>
          </a>
          {
            navItems.map((item) => {
              const Icon = iconMap[item.icon];
              return (
                <a class="nav-link" href={`#${item.id}`}>
                  <Icon size={17} aria-hidden="true" />
                  <span>{item.title.replace("Apps & Websites", "Apps & Web").replace("Industrial Cybersecurity", "Security")}</span>
                </a>
              );
            })
          }
        </nav>
      </header>

      <main>
        <section class="hero panel reveal" aria-labelledby="hero-title">
          <div class="hero-grid">
            <img class="hero-portrait" src={asset(profile.portrait)} alt={profile.portraitAlt} loading="eager" />
            <div class="hero-copy">
              <h1 id="hero-title">{profile.title}</h1>
              <p>{profile.tagline}</p>
            </div>
          </div>

          <div class="area-grid" aria-label="Activity areas">
            {
              activityAreas.slice(1, 5).map((area) => {
                const Icon = iconMap[area.icon];
                return (
                  <a class="area-card" href={`#${area.id}`} data-theme={area.theme}>
                    <span class="area-icon">
                      <Icon size={31} aria-hidden="true" />
                    </span>
                    <strong>{area.title}</strong>
                    <span>{area.labelJa}</span>
                  </a>
                );
              })
            }
          </div>

          <div class="external-links">
            <h2>
              <LinkIcon size={21} aria-hidden="true" />
              外部リンク
            </h2>
            <div class="external-grid">
              {
                externalLinks.map((item) => {
                  const Icon = iconMap[item.icon];
                  const isReady = item.status === "ready" && item.url;
                  return isReady ? (
                    <a class="external-card" href={item.url} target="_blank" rel="noreferrer">
                      <Icon size={26} aria-hidden="true" />
                      <span>{item.label}</span>
                      <ExternalLink size={16} aria-hidden="true" />
                    </a>
                  ) : (
                    <span class="external-card is-disabled" aria-disabled="true">
                      <Icon size={26} aria-hidden="true" />
                      <span>{item.label}</span>
                      <small>準備中</small>
                    </span>
                  );
                })
              }
            </div>
          </div>
        </section>

        <section class="panel section section-app reveal" id="apps" aria-labelledby="apps-title">
          <SectionHeading
            id="apps-title"
            title="Apps & Websites"
            description="効率的で美しいアプリと Web サイトを制作しています。"
            icon={sectionIconMap.apps}
            theme="app"
            ctaLabel="すべてのプロジェクトを見る"
            ctaHref="https://github.com/TatsuyaKakamu"
          />
          <div class="project-grid">
            {
              projects.map((project) => {
                const hasShot = Boolean(project.screenshot);
                const shotClass = `project-shot${hasShot ? "" : " is-placeholder"}`;
                const projectUrl = project.demoUrl || project.repositoryUrl;
                const projectLinkLabel = project.demoUrl
                  ? `${project.name} のデモサイトを開く`
                  : `${project.name} のGitHubリポジトリを開く`;
                const shotInner = hasShot ? (
                  <img src={asset(project.screenshot)} alt={project.screenshotAlt} loading="lazy" />
                ) : (
                  <Fragment>
                    <ImageIcon size={28} aria-hidden="true" />
                    <span>プレビュー準備中</span>
                  </Fragment>
                );
                return (
                  <article class="project-card">
                    {projectUrl ? (
                      <a
                        class={shotClass}
                        href={projectUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={projectLinkLabel}
                      >
                        {shotInner}
                      </a>
                    ) : (
                      <span class={shotClass}>{shotInner}</span>
                    )}
                    <div class="project-copy">
                      <h3>
                        {projectUrl ? (
                          <a class="project-title-link" href={projectUrl} target="_blank" rel="noreferrer">
                            {project.name}
                          </a>
                        ) : (
                          project.name
                        )}
                      </h3>
                      <p>{project.description}</p>
                      <div class="tag-row" aria-label={`${project.name} tech stack`}>
                        {project.techStack.map((tech) => (
                          <span>{tech}</span>
                        ))}
                      </div>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </section>

        <section class="panel section section-security reveal" id="security" aria-labelledby="security-title">
          <SectionHeading
            id="security-title"
            title="Security / Certification"
            description="産業用サイバーセキュリティの基礎を体系的に学び、資格を取得しています。"
            icon={sectionIconMap.security}
            theme="security"
          />
          <div class="security-grid">
            <article class="certificate-card">
              <img class="certificate-mark" src={asset(certification.markImage)} alt={certification.markAlt} loading="lazy" />
              <div class="certificate-copy">
                <p class="eyebrow">{certification.issuer}</p>
                <h3>{certification.name}</h3>
                <p>{certification.standard}</p>
                <dl class="certificate-list">
                  <div>
                    <dt>取得者</dt>
                    <dd>{certification.holderName}</dd>
                  </div>
                  <div>
                    <dt>発行日</dt>
                    <dd>{certification.issueDate}</dd>
                  </div>
                  <div>
                    <dt>ID</dt>
                    <dd>{certification.certificationId}</dd>
                  </div>
                </dl>
                <a class="button button-security" href={certification.verificationUrl} target="_blank" rel="noreferrer">
                  TÜV SÜD 資格検証ページを見る
                  <ExternalLink size={16} aria-hidden="true" />
                </a>
              </div>
            </article>

            <article class="info-card">
              <h3>
                <BadgeCheck size={21} aria-hidden="true" />
                IEC 62443 とは？
              </h3>
              <p>
                産業用オートメーションと制御システムのセキュリティに関する国際規格群です。
                本資格は、その基礎知識を体系的に学習した証明として扱います。
              </p>
              <h3>
                <ShieldCheck size={21} aria-hidden="true" />
                主な領域
              </h3>
              <p>
                産業制御システムのリスク評価、セキュア設計、脅威モデリング、組織的な対策への理解を深めています。
              </p>
            </article>
          </div>
        </section>

        <section class="panel section section-photo reveal" id="photography" aria-labelledby="photography-title">
          <SectionHeading
            id="photography-title"
            title="Photography"
            description="日常の中で出会う風景や瞬間を、写真として記録しています。"
            icon={sectionIconMap.photography}
            theme="photography"
            ctaLabel="Instagram を見る"
            ctaHref={instagramUrl}
          />
          <div class="photo-grid">
            {
              photos.map((photo, index) => (
                <figure style={`--photo-index: ${index};`}>
                  <span class="shutter shutter-top" aria-hidden="true" />
                  <span class="shutter shutter-bottom" aria-hidden="true" />
                  <span class="shutter-flash" aria-hidden="true" />
                  <img src={asset(photo.image)} alt={photo.alt} loading="lazy" />
                  <figcaption>{photo.caption}</figcaption>
                </figure>
              ))
            }
          </div>
        </section>

        <section class="panel section section-training reveal" id="training" aria-labelledby="training-title">
          <SectionHeading
            id="training-title"
            title="Training"
            description="トレーニングを習慣化し、心身のコンディションを整えています。"
            icon={sectionIconMap.training}
            theme="training"
            ctaLabel="Strava を見る"
            ctaHref={training.stravaUrl}
            disabled={!training.stravaUrl}
          />
          <div class="metric-grid metric-grid--three">
            <MetricCard
              icon={Clock}
              label="先月の総トレーニング"
              value={training.lastMonthTotalHours}
              unit="時間"
              note={`前月比 ${training.lastMonthDeltaHours >= 0 ? "+" : ""}${training.lastMonthDeltaHours.toFixed(1)}時間`}
            />
            <MetricCard
              icon={Hourglass}
              label="今年の総トレーニング時間"
              value={training.yearTotalHours}
              unit="時間"
              note={`${training.period.year}年`}
            />
            <MetricCard
              icon={Flame}
              label="総継続習慣"
              value={training.streak.label}
              unit=""
              note={`${training.streak.startDate} から継続中`}
              cardClass="metric-card--streak"
            />
          </div>
          <div class="training-board">
            <div class="bar-chart" aria-label="月のトレーニング時間">
              <h3>月のトレーニング時間（h）</h3>
              <div class="bars">
                {
                  training.monthlyHours.map((entry) => (
                    <div class="bar-item">
                      <span>{entry.hours}</span>
                      <i style={`height: ${Math.max(18, Math.min(104, entry.hours * 4))}px`} aria-hidden="true"></i>
                      <small>{entry.label}</small>
                    </div>
                  ))
                }
              </div>
            </div>
            <div class="monthly-average">
              <span>6ヶ月平均</span>
              <strong>{training.averageMonthlyHours} h</strong>
            </div>
          </div>
        </section>

        <section class="panel section section-about reveal" id="about" aria-labelledby="about-title">
          <SectionHeading
            id="about-title"
            title="About"
            description="シンプルに、今の自分について。"
            icon={sectionIconMap.about}
            theme="about"
          />
          <div class="about-grid">
            <img src={asset(profile.portrait)} alt={profile.portraitAlt} loading="lazy" />
            <div class="about-copy">
              <h3>{profile.name}</h3>
              <div class="badge-row">
                {
                  profile.badges.map((badge) => (
                    <span data-theme={badge.theme}>{badge.label}</span>
                  ))
                }
              </div>
              <p>{profile.summary}</p>
              <p class="note">
                このサイトは個人の活動をまとめたものです。会社名・勤務地・連絡先情報は掲載していません。
              </p>
            </div>
            <aside class="focus-card" aria-label="活動領域">
              <h3>活動領域</h3>
              <ul>
                <li>アプリケーション開発</li>
                <li>産業用サイバーセキュリティの学習</li>
                <li>写真撮影</li>
                <li>トレーニング / ランニング</li>
              </ul>
            </aside>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="footer-icons" aria-label="External services">
          <CodeXml size={26} aria-hidden="true" />
          <BadgeCheck size={26} aria-hidden="true" />
          <Camera size={26} aria-hidden="true" />
          <Activity size={26} aria-hidden="true" />
        </div>
        <small>© 2025 {profile.name}</small>
      </footer>
    </div>

    <script>
      const sections = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.14 }
      );
      sections.forEach((section) => observer.observe(section));
    </script>
  </body>
</html>
