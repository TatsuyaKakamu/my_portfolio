---
const { icon: Icon, label, value, valueParts, unit, note, cardClass, staggerGroup } = Astro.props;
const isNumeric = typeof value === "number";
const hasParts = Array.isArray(valueParts) && valueParts.length > 0;
const stageAttr = typeof staggerGroup === "number" ? String(staggerGroup) : undefined;
---

<article class:list={["metric-card", cardClass]} data-countup-stage={stageAttr}>
  <Icon size={28} aria-hidden="true" />
  <span>{label}</span>
  <strong>
    {hasParts ? (
      valueParts.map((part: { value: number; suffix?: string }) => (
        <>
          <span class="metric-value" data-countup={String(part.value)}>{part.value}</span>
          {part.suffix ? <small>{part.suffix}</small> : null}
        </>
      ))
    ) : isNumeric ? (
      <span class="metric-value" data-countup={String(value)}>{value}</span>
    ) : (
      value
    )}
    {unit ? <small>{unit}</small> : null}
  </strong>
  <em>{note}</em>
</article>
