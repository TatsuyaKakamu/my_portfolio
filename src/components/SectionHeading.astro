---
import { ArrowRight } from "@lucide/astro";

const { id, title, description, icon: Icon, theme, ctaLabel, ctaHref, disabled = false } = Astro.props;
const isExternal = typeof ctaHref === "string" && /^https?:\/\//.test(ctaHref);
---

<div class="section-heading">
  <div class="heading-main">
    <span class="section-icon" data-theme={theme}>
      <Icon size={33} aria-hidden="true" />
    </span>
    <div>
      <h2 id={id}>{title}</h2>
      <p>{description}</p>
    </div>
  </div>
  {
    ctaLabel ? (
      disabled ? (
        <span class="section-cta is-disabled" aria-disabled="true">
          {ctaLabel}
          <ArrowRight size={17} aria-hidden="true" />
        </span>
      ) : (
        <a
          class="section-cta"
          href={ctaHref ?? "#"}
          {...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
        >
          {ctaLabel}
          <ArrowRight size={17} aria-hidden="true" />
        </a>
      )
    ) : null
  }
</div>
